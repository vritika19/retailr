\name{retailr-package}
\alias{retailr}
\title{retailr: Fashion Product Segmentation and Profit-Tier Analysis}
\description{
retailr provides an end-to-end pipeline for segmenting fashion retail products
into profit tiers using PCA, t-SNE, cross-validated K-means clustering, and
kNN classification.
}
\author{Vritika \email{vritika25@iitk.ac.in}}
